{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "dialog:default",
    "notification:default",
    "clipboard-manager:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/python-engine",
          "sidecar": true
        }
      ]
    }
  ]
}